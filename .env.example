## Example environment file for Plant Analysis Tool
# Recommended: use a service account JSON for the Generative Language API (set via
# the GOOGLE_APPLICATION_CREDENTIALS environment variable). If you prefer a short-lived
# access token for testing, set `GEMINI_API_KEY` to the token value.

# Gemini API key or short-lived OAuth token (debug/testing only)
GEMINI_API_KEY=

# Optional: port the server will listen on (defaults to 5000)
PORT=5000

# Optional: path to service-account JSON (preferred for production)
# Example (PowerShell):
# $env:GOOGLE_APPLICATION_CREDENTIALS = 'C:\keys\gen-ai-sa.json'
GOOGLE_APPLICATION_CREDENTIALS=

# Notes:
# - Do NOT commit service account JSON files or real keys to git.
# - Keep a copy of this file as .env.example and create a private .env for runtime values.